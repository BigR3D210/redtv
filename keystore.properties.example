# Copy this file to "keystore.properties" (same folder) and fill in real values.
# Then `./gradlew assembleRelease` (or Build > Generate Signed APK) produces a
# signed, shareable APK. Keep keystore.properties and your .jks file private.
storeFile=redtv-release.jks
storePassword=CHANGE_ME
keyAlias=redtv
keyPassword=CHANGE_ME
