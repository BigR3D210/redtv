<?xml version="1.0" encoding="utf-8"?>
<!-- Many IPTV providers serve over plain http, so cleartext is allowed.
     Streams are loaded from URLs you control via your account config. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
